{
  "name": "pollis",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "WEBKIT_DISABLE_COMPOSITING_MODE=1 GDK_BACKEND=x11 cargo tauri dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "build": "cargo tauri build",
    "build:linux": "cargo tauri build --target x86_64-unknown-linux-gnu",
    "build:macos": "cargo tauri build --target universal-apple-darwin",
    "build:windows": "cargo tauri build --target x86_64-pc-windows-msvc",
    "lint": "pnpm --filter frontend lint",
    "clean": "pnpm --filter frontend clean && cargo clean --manifest-path src-tauri/Cargo.toml",
    "secrets:decrypt": "sops --decrypt --input-type dotenv --output-type dotenv secrets.enc.env > .env.development",
    "secrets:encrypt": "sops --encrypt --filename-override secrets.enc.env --input-type dotenv --output-type dotenv .env.development > secrets.enc.env",
    "secrets:edit": "sops --filename-override secrets.enc.env --input-type dotenv --output-type dotenv secrets.enc.env",
    "db:push": "cargo run --manifest-path src-tauri/Cargo.toml --bin migrate"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2"
  },
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=18"
  }
}
