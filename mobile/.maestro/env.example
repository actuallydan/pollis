# Maestro seed/environment for the Pollis mobile e2e suite (#619).
# Copy to `mobile/.maestro/.env` (gitignored) on the Mac and fill in.
# The runner script passes these to `maestro test -e KEY=VALUE …`, and flows
# read them as `${KEY}`. NEVER put real secrets here — this is dev-DS only.
#
# The app build under test must point at the DEV Delivery Service
# (EXPO_PUBLIC_POLLIS_DELIVERY_URL=https://api-dev.pollis.com) and a dev
# LiveKit URL for the realtime flow. Those are build-time (baked into the dev
# build), not Maestro env — see README "Build under test".

# --- Primary test account (drives most flows) ---
# A disposable dev-DS account. First run signs it up; later runs restore it.
MAESTRO_EMAIL=pollis-e2e+primary@example.com

# The OTP the dev DS returns. The dev DS is configured with a fixed DEV_OTP so
# the harness is deterministic (no inbox polling). Match it to the dev DS value.
MAESTRO_OTP=000000

# The device PIN the auth flow sets/uses (6 digits).
MAESTRO_PIN=123456

# --- Peer account (for DM / group / realtime two-client flows) ---
# Used by the two-device flows (see README "Two-client flows"). The peer runs
# on a SECOND simulator/emulator driven by a parallel Maestro invocation.
MAESTRO_PEER_EMAIL=pollis-e2e+peer@example.com
MAESTRO_PEER_HANDLE=pollis_e2e_peer
