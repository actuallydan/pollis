# Turso Database Configuration
# Get your database URL and auth token from https://turso.tech

# Option 1: Use DB_URL with embedded auth token
DB_URL=libsql://your-database-name.turso.io?authToken=your-auth-token

# Option 2: Use separate TURSO_URL and TURSO_TOKEN
# TURSO_URL=libsql://your-database-name.turso.io
# TURSO_TOKEN=your-auth-token

# Cloudflare R2 Storage
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_KEY=your-secret-key
R2_S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com/your-bucket
# Public URL for serving R2 files (custom domain or R2 dev URL)
R2_PUBLIC_URL=https://cdn.pollis.com

# Dev bypass: set this to skip email sends during local development.
# The OTP step still appears but you can enter this fixed code instead.
# DEV_OTP=000000

# Note: Copy this file to .env.development and fill in your actual credentials
