# Turso Database Configuration
# Get your database URL and auth token from https://turso.tech

# Option 1: Use DB_URL with embedded auth token
DB_URL=libsql://your-database-name.turso.io?authToken=your-auth-token

# Option 2: Use separate TURSO_URL and TURSO_TOKEN
# TURSO_URL=libsql://your-database-name.turso.io
# TURSO_TOKEN=your-auth-token

# Commit-log database (optional). The MLS control-plane tables (mls_commit_log,
# mls_group_info, mls_welcome) live in their own Turso DB so the Delivery
# Service can be the sole writer (see docs/goal-a-commit-log-sole-writer.md).
# When unset, the client falls back to the main DB above for these tables.
# LOG_DB_URL — URL of the separate commit-log Turso DB (client + DS).
# LOG_DB_TOKEN — READ-ONLY token, embedded in client builds.
# LOG_DB_ADMIN_TOKEN — READ-WRITE token, for migrations + the Delivery Service
#   ONLY; never ship it in client builds.
# LOG_DB_URL=libsql://your-commit-log-db.turso.io
# LOG_DB_TOKEN=your-read-only-token
# LOG_DB_ADMIN_TOKEN=your-read-write-token

# Cloudflare R2 Storage
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_KEY=your-secret-key
R2_S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com/your-bucket
# Public URL for serving R2 files (custom domain or R2 dev URL)
R2_PUBLIC_URL=https://cdn.pollis.com

# Resend (email OTP delivery). Required to construct Config even when you use
# the DEV_OTP / DEV_EMAIL bypass below — a placeholder string is fine in that case.
# Get a key from https://resend.com
RESEND_API_KEY=your-resend-api-key

# LiveKit SFU (voice / screenshare real-time media). Point these at your own
# self-hosted server (see livekit/DEPLOY.md and livekit/livekit.yml) or LiveKit Cloud.
# api key/secret must match the `keys:` block in your livekit.yml.
LIVEKIT_URL=wss://your-livekit-domain.example.com
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# Delivery Service (optional). When set, MLS commit submission routes through
# the DS, which serializes commits per conversation (race-free, gap-free).
# Leave unset to write commits directly to Turso (the default / self-host path).
# Prod desktop builds use https://api.pollis.com; dev uses https://api-dev.pollis.com.
# POLLIS_DELIVERY_URL=https://api.pollis.com

# Dev bypass: set this to skip email sends during local development.
# The OTP step still appears but you can enter this fixed code instead.
# DEV_OTP=000000
# Or auto-login as a fixed email on startup, skipping OTP entirely:
# DEV_EMAIL=you@example.com

# Note: Copy this file to .env.development and fill in your actual credentials
