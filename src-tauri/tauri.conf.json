{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pollis",
  "version": "1.0.43",
  "identifier": "com.pollis.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter frontend dev",
    "beforeBuildCommand": "pnpm --filter frontend build"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Pollis",
        "width": 540,
        "height": 360,
        "minWidth": 540,
        "minHeight": 360,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "macOS": {
      "signingIdentity": null,
      "notarizationCredentials": {
        "appleId": {
          "envVariable": "APPLE_ID"
        },
        "appleIdPassword": {
          "envVariable": "APPLE_PASSWORD"
        },
        "teamId": {
          "envVariable": "APPLE_TEAM_ID"
        }
      }
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
