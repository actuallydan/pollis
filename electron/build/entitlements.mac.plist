<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Standard Electron-hardened-runtime requirements. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>

  <!-- Media capture: mirrors src-tauri/Entitlements.plist (audio-input)
       and adds camera + screen-capture for future video parity. -->
  <key>com.apple.security.device.audio-input</key>
  <true/>
  <key>com.apple.security.device.camera</key>
  <true/>

  <!-- Network: client for Turso/LiveKit/R2; server for the local media
       loopback HTTP server documented in CLAUDE.md's "Performance
       Architecture" section (pollis-core binds 127.0.0.1:<auto-port> for
       <img>/<audio>/<video> serving). -->
  <key>com.apple.security.network.client</key>
  <true/>
  <key>com.apple.security.network.server</key>
  <true/>

  <!-- File access for user-chosen attachments + downloads. -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>
</dict>
</plist>
