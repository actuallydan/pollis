# Load secrets from encrypted file via sops
# Requires: sops + age key at ~/.config/sops/age/keys.txt
# To re-encrypt after editing: make secrets-encrypt
dotenv <(sops --decrypt --input-type dotenv --output-type dotenv secrets.enc.env)

# Fix WebKit/Go signal handler conflicts in Wails (legacy, kept for safety)
# do we need this?
export GODEBUG=asyncpreemptoff=1
export WEBKIT_DISABLE_COMPOSITING_MODE=1
export GOTRACEBACK=all
